rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Global Reusable Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Check if user is a designated administrator
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "18sparweb@gmail.com" ||
        request.auth.token.email == "content2u.sj@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 1. PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true; // Publicly viewable catalog
      
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if (isAdmin() && isValidProduct(incoming())) || (
        // Allow public customers to submit reviews (which updates product.reviews and product.rating)
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['reviews', 'rating'])
      );
      allow delete: if isAdmin();
    }

    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.price is number && data.price > 0 &&
             data.stock is int && data.stock >= 0;
    }

    // 2. ORDERS COLLECTION
    match /orders/{orderId} {
      // Allow user to read their own orders, or allow admin to read all
      allow read: if isAdmin() || (isSignedIn() && existing().shippingAddress.email == request.auth.token.email);
      
      // Allow any signed-in user to create an order
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId);
      
      // Allow update of orderStatus only by Admin, or allow cancellation by Owner
      allow update: if isAdmin() || (
        isSignedIn() && 
        existing().shippingAddress.email == request.auth.token.email &&
        incoming().diff(existing()).affectedKeys().hasOnly(['orderStatus']) &&
        incoming().orderStatus == 'Returned' && 
        existing().orderStatus != 'Delivered'
      );
      
      allow delete: if isAdmin();
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.date is string &&
             data.total is number && data.total >= 0 &&
             data.paymentStatus is string &&
             data.orderStatus is string;
    }

    // 3. NEWSLETTERS COLLECTION (Subscriptions)
    match /newsletters/{emailId} {
      allow read: if isAdmin();
      // Allow any guest to submit an email to subscribe to drops
      allow create: if incoming().email is string && incoming().email.size() <= 128 && isValidId(emailId);
      allow update, delete: if isAdmin();
    }
  }
}
